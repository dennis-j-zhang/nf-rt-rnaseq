// nf-rt-rnaseq — MAF AWS Batch config (patterned on FischbachLab/nf-ninjamap). v0.1.0
// Head job runs on priority-maf-pipelines (shared `nextflow-production` job def); this config
// dispatches per-accession TASK jobs to default-maf-pipelines (spot).

manifest {
    name            = 'nf-rt-rnaseq'
    description      = "RT-flanking transcription screen: map each RT locus's own SRA RNA-seq run; score immediate-flank IGR coverage / RT-ORF mean depth."
    author          = 'Dennis Zhang (Fischbach lab)'
    version         = '0.1.0'
    defaultBranch    = 'main'
    nextflowVersion = '>=22.10.0'
}

params {
    seedfile       = null                                           // CSV (header: sra_accession,loci); see bin/make_seedfile.py
    project        = 'run'                                          // -> output subfolder
    output_path    = 's3://genomics-workflow-core/Results/rt-rnaseq' // MAF-mandated results bucket
    erda_secret_id = 'erda_dk'                                      // Secrets Manager secret holding the ERDA bearer URL
    aws_region     = 'us-west-2'
    short_aligner  = 'bowtie2'                                      // aligner verdict (short); long reads auto-route to minimap2
    max_sra_gb     = 20
    igr_min        = 1
    igr_max        = 3
    container      = '458432034220.dkr.ecr.us-west-2.amazonaws.com/nf-rt-rnaseq:latest'  // build + push, see README
}

process {
    executor      = 'awsbatch'
    queue         = 'default-maf-pipelines'                         // spot
    container     = params.container
    cpus          = 8
    memory        = '30 GB'                                         // feasibility: RAM ~1 GB, but the FASTQ balloon (8.5x) needs disk headroom
    errorStrategy = { task.exitStatus in [143,137,104,134,139,247] ? 'retry' : 'finish' }
    maxRetries    = 2
    cache         = false
}

aws {
    region = params.aws_region
    batch { cliPath = '/usr/local/bin/aws' }
}

docker { enabled = true }

profiles {
    debug { process.beforeScript = 'echo HOST=$HOSTNAME; df -h /' }
}
